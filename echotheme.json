{
  "name": "ECHO New",
  "author": "Gostyk",
  "version": "1.0.0",
  "colors": {
    "accent": "#3E42C6",
    "accent_hover": "#3E42C6",
    "success": "#61C73D",
    "danger": "#982929",

    "status_online": "#43b581",
    "status_idle": "#faa61a",
    "status_dnd": "#982929",
    "status_streaming": "#593695",
    "status_offline": "#808080",

    "text_normal": "#d8d8db",
    "text_muted": "#aeaeb4"
  },
  "background": {
    "image": "https://i.imgur.com/6pCVmcK.png",
    "position": "center",
    "size": "cover",
    "attachment": "fixed",
    "shading_dark": "rgba(0, 0, 0, 0.6)",
    "shading_midnight": "rgba(0, 0, 0, 0.8)"
  },
  "channels": {
    "selected_background": "#3E42C6",
    "unread": "#3E42C6",
    "unread_hover": "#3E42C6"
  },
  "fonts": {
    "main": "gg sans, Helvetica Neue, Helvetica, Arial, sans-serif",
    "code": "Consolas, gg mono, Liberation Mono, Menlo, Courier, monospace"
  },
  "effects": {
    "background_filter": "saturate(1)"
  }
}
